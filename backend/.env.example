# Copy this file to backend/.env and fill in the values for this machine.

# Path to the downloaded Qwen3-TTS model snapshot (see qwen/HOW_TO_RUN.md step 3).
MODEL_PATH=D:\models_cache\models--Qwen--Qwen3-TTS-12Hz-0.6B-Base\snapshots\<snapshot-id>

# Only needed if the frontend is served from a different origin than the backend
# (e.g. the Vite dev server on :5173, or a split Vercel+RunPod deployment).
# NOT needed for a LAN server setup -- backend/main.py serves the built
# frontend/dist directly from the same origin/port once you've run
# `npm run build` in frontend/, so there's nothing cross-origin to allow.
ALLOWED_ORIGINS=http://localhost:5173

# Optional -- only relevant if this machine is a RunPod pod with idle
# auto-stop configured. Leave unset for a normal always-on LAN server.
# RUNPOD_API_KEY=
# RUNPOD_POD_ID=
# IDLE_CHECK_INTERVAL_MIN=10
# IDLE_STOP_THRESHOLD_MIN=10
